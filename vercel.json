{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api/index.js" },
    { "source": "/inspect", "destination": "/api/index.js" }
  ]
}
